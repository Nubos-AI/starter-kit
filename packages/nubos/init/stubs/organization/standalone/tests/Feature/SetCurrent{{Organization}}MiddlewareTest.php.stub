<?php

declare(strict_types=1);

use App\Http\Middleware\SetCurrent{{Organization}};
use App\Models\{{Organization}};
use App\Models\User;
use Illuminate\Foundation\Testing\RefreshDatabase;
use Illuminate\Http\Request;
use Illuminate\Routing\Route;
use Symfony\Component\HttpKernel\Exception\AccessDeniedHttpException;
use Symfony\Component\HttpKernel\Exception\NotFoundHttpException;

uses(RefreshDatabase::class);

function createRequestWith{{Organization}}(mixed ${{organization}}, ?User $user = null): Request
{
    $request = Request::create('/test');
    $route = new Route('GET', '/test/{{{organization}}}', []);
    $route->bind($request);
    $route->setParameter('{{organization}}', ${{organization}});
    $request->setRouteResolver(fn () => $route);
    $request->setUserResolver(fn () => $user);

    return $request;
}

it('sets current {{organization}} in the container for a valid member', function (): void {
    ${{organization}} = {{Organization}}::factory()->create();
    $user = User::query()->find(${{organization}}->owner_id);

    $request = createRequestWith{{Organization}}(${{organization}}, $user);

    $middleware = new SetCurrent{{Organization}};
    $middleware->handle($request, fn () => new \Illuminate\Http\Response);

    expect(app()->bound('current{{Organization}}'))->toBeTrue()
        ->and(app('current{{Organization}}')->id)->toBe(${{organization}}->id);
});

it('throws 404 when {{organization}} route parameter is invalid', function (): void {
    $user = User::factory()->create();

    $request = createRequestWith{{Organization}}('invalid-id', $user);

    $middleware = new SetCurrent{{Organization}};
    $middleware->handle($request, fn () => new \Illuminate\Http\Response);
})->throws(NotFoundHttpException::class);

it('throws 403 when user is not a member', function (): void {
    ${{organization}} = {{Organization}}::factory()->create();
    $stranger = User::factory()->create();

    $request = createRequestWith{{Organization}}(${{organization}}, $stranger);

    $middleware = new SetCurrent{{Organization}};
    $middleware->handle($request, fn () => new \Illuminate\Http\Response);
})->throws(AccessDeniedHttpException::class);

it('throws 404 when {{organization}} route parameter is missing', function (): void {
    $user = User::factory()->create();

    $request = createRequestWith{{Organization}}(null, $user);

    $middleware = new SetCurrent{{Organization}};
    $middleware->handle($request, fn () => new \Illuminate\Http\Response);
})->throws(NotFoundHttpException::class);
