{
    "name": "nubos/init",
    "description": "Nubos StarterKit initialization package",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nubos\\Init\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nubos\\Init\\Providers\\NubosInitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
