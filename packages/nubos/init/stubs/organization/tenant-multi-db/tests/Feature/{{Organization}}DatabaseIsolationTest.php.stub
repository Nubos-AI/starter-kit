<?php

declare(strict_types=1);

use App\Models\{{Organization}};
use App\Models\Tenant;
use Illuminate\Foundation\Testing\RefreshDatabase;

uses(RefreshDatabase::class);

it('uses tenant database connection', function (): void {
    $model = new {{Organization}};

    expect($model->getConnectionName())->toBe('tenant');
});

it('does not have tenant_id column in fillable', function (): void {
    $model = new {{Organization}};

    expect($model->getFillable())->not->toContain('tenant_id');
});

it('stores {{organizations}} in the tenant database', function (): void {
    $tenant = Tenant::factory()->create(['database' => 'tenant_test_{{organizations}}']);
    $tenant->configureDatabaseConnection();

    $model = new {{Organization}};
    expect($model->getConnectionName())->toBe('tenant')
        ->and(config('database.connections.tenant.database'))->toBe('tenant_test_{{organizations}}');
});

it('fails to access sub-{{organization}} route without tenant context', function (): void {
    $user = \App\Models\User::factory()->create();

    $this->actingAs($user)
        ->get("/{{organizations}}/some-id/dashboard")
        ->assertNotFound();
});

it('resolves pivot relation via tenant connection', function (): void {
    $tenant = Tenant::factory()->create(['database' => 'tenant_test_pivot']);
    $tenant->configureDatabaseConnection();

    $user = new \App\Models\User();
    $relation = $user->{{organizations}}();

    expect($relation->getPivotClass())->toBe(\App\Models\{{Organization}}User::class)
        ->and((new \App\Models\{{Organization}}User())->getConnectionName())->toBe('tenant');
});
