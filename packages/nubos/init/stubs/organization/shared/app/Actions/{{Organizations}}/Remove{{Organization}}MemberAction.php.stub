<?php

declare(strict_types=1);

namespace App\Actions\{{Organizations}};

use App\Events\{{Organizations}}\MemberRemoved;
use App\Models\{{Organization}};
use App\Models\User;

class Remove{{Organization}}MemberAction
{
    public function execute({{Organization}} ${{organization}}, User $user): void
    {
        ${{organization}}->members()->detach($user);

        MemberRemoved::dispatch(${{organization}}, $user);
    }
}
