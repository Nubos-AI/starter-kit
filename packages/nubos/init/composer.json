{
    "name": "nubos/init",
    "description": "Nubos organization scaffolding — interactive setup for Team, Workspace, or Tenant structures.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/console": "^12.0",
        "illuminate/filesystem": "^12.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nubos\\Init\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nubos\\Init\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nubos\\Init\\NubosInitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
